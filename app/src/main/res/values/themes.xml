<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base theme. Compose drives the real colors; this just sets a warm window
         background so there is never a white/black flash before the first frame. -->
    <style name="Theme.PaperNotes" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/paper_cream</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <!-- Splash screen (androidx core-splashscreen). Hands off to Theme.PaperNotes. -->
    <style name="Theme.PaperNotes.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/paper_cream</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.PaperNotes</item>
    </style>

</resources>
